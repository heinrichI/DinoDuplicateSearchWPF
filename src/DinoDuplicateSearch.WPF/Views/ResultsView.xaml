<UserControl x:Class="DinoDuplicateSearch.Views.ResultsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:DinoDuplicateSearch.ViewModels"
             xmlns:models="clr-namespace:DinoDuplicateSearch.Models;assembly=DinoDuplicateSearch.Models"
             xmlns:views="clr-namespace:DinoDuplicateSearch.Views">

    <Border Background="#FFF5F5F5">
        <Border Margin="20" Background="White" CornerRadius="8" Padding="24"
                BorderBrush="#FFE0E0E0" BorderThickness="1">
            <DockPanel>
                <!-- Header -->
                <Border DockPanel.Dock="Top" Margin="0,0,0,12">
                    <Grid>
                        <TextBlock Text="Duplicate Groups" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding CountText}" HorizontalAlignment="Right" VerticalAlignment="Center"
                                   FontSize="14" Foreground="#FF666666"/>
                    </Grid>
                </Border>

                <!-- Scrollable Results -->
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding Groups}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:DuplicateGroup}">
                                <Border Margin="0,0,0,12" BorderBrush="#FFD0D0D0" BorderThickness="1"
                                        CornerRadius="6" Padding="12" Background="#FFFAFAFA">
                                    <StackPanel>
                                        <!-- Group Header -->
                                        <Grid Margin="0,0,0,8">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock FontWeight="Bold" FontSize="14">
                                                    <Run Text="Group "/>
                                                    <Run Text="{Binding ClusterId, Mode=OneWay}"/>
                                                    <Run Text=" ("/>
                                                    <Run Text="{Binding Paths.Count, Mode=OneWay}"/>
                                                    <Run Text=" images)"/>
                                                </TextBlock>
                                            </StackPanel>
                                            <TextBlock HorizontalAlignment="Right" FontSize="12" Foreground="#FF666666">
                                                <TextBlock.Text>
                                                    <MultiBinding StringFormat="Avg similarity: {0:F4}">
                                                        <Binding Path="AvgSimilarity"/>
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                        </Grid>

                                        <!-- Separator -->
                                        <Border Height="1" Background="#FFD0D0D0" Margin="0,0,0,8"/>

                                        <!-- Thumbnails -->
                                        <ItemsControl ItemsSource="{Binding Paths}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel Orientation="Horizontal"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="{x:Type sys:String}" xmlns:sys="clr-namespace:System;assembly=mscorlib">
                                                    <Border Width="150" Margin="4" Cursor="Hand" Tag="{Binding}">
                                                        <Border.InputBindings>
                                                            <MouseBinding MouseAction="LeftDoubleClick"
                                                                          Command="{Binding DataContext.OpenImageCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                          CommandParameter="{Binding}"/>
                                                        </Border.InputBindings>
                                                        <StackPanel>
                                                            <Border Height="120" Background="#FFF0F0F0" CornerRadius="4"
                                                                    ClipToBounds="True">
                                                                <Image Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality"
                                                                       Source="{Binding Converter={x:Static views:StringToBitmapImageConverter.Instance}, Mode=OneWay}"/>
                                                            </Border>
                                                            <TextBlock Text="{Binding}" FontSize="10" TextAlignment="Center"
                                                                       TextTrimming="CharacterEllipsis" Margin="0,4,0,0"
                                                                       Foreground="#FF444444"/>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </Border>
    </Border>
</UserControl>
